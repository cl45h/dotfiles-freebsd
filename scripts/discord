#!/bin/sh
export ELECTRON_IS_DEV=0
export LIBGL_DRI3_DISABLE=1
export LIBGL_ALWAYS_SOFTWARE=1
export NODE_ENV=production
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    # Source the real FreeBSD dbus session address instead of "autolaunch:"
    # which tries /usr/bin/dbus-launch (Linux path) and crashes
    _dbus_file=$(find /home/cl45h/.dbus/session-bus/ -type f 2>/dev/null | head -1)
    if [ -n "$_dbus_file" ]; then
        eval $(grep '^DBUS_SESSION_BUS_ADDRESS=' "$_dbus_file")
        export DBUS_SESSION_BUS_ADDRESS
    else
        export DBUS_SESSION_BUS_ADDRESS="disabled:"
    fi
fi
exec /home/cl45h/.local/share/discord/Discord \
    --no-sandbox \
    --no-zygote \
    --disable-gpu \
    --disable-gpu-compositing \
    --in-process-gpu \
    --disable-breakpad \
    --enable-features=UseOzonePlatform \
    --ozone-platform=x11 \
    "$@"
